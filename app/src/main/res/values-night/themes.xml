<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.KdexMusicPlayer" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Vibrant Dark Theme (Night) -->
        <item name="colorPrimary">@color/vibrant_red</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/black</item>
        <item name="colorOnPrimaryContainer">@color/vibrant_red</item>

        <item name="colorSecondary">@color/vibrant_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/black</item>
        <item name="colorOnSecondaryContainer">@color/vibrant_blue</item>

        <item name="colorTertiary">@color/vibrant_green</item>
        <item name="colorOnTertiary">@color/black</item>

        <!-- Pure Black background for OLED -->
        <item name="android:windowBackground">@color/black</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/text_high_emphasis</item>
        <item name="colorSurfaceVariant">@color/deep_dark_surface</item>
        <item name="colorOnSurfaceVariant">@color/text_medium_emphasis</item>

        <item name="colorOutline">@color/deep_dark_surface_variant</item>
    </style>
</resources>
